# Copy this file to .env and fill in real values.
# .env is git-ignored and should never be committed.

# development | production | testing
FLASK_ENV=development

# Used by Flask to sign session cookies. Generate a real random value for .env
# e.g. run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# SQLAlchemy database URI. SQLite file lives in the instance/ folder.
DATABASE_URL=sqlite:///database.db
